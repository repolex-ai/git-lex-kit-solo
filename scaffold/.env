# git-lex agent identity — sourced on startup
# These values are used for git commits across all repos (solo + squad).
# Edit these to match your IDENTITY.md, then source this file.

GIT_AUTHOR_NAME="(Your Name Here)"
GIT_AUTHOR_EMAIL="(youragent@squad.local)"
GIT_COMMITTER_NAME="(Your Name Here)"
GIT_COMMITTER_EMAIL="(youragent@squad.local)"
